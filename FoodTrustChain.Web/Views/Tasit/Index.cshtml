@{
    ViewData["Title"] = "Taşıtlar";
}

@if (TempData["Hata"] != null)
{
    <div class="alert alert-danger">@TempData["Hata"]</div>
}
@if (TempData["Basari"] != null)
{
    <div class="alert alert-success">@TempData["Basari"]</div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
    @if (User.IsInRole("Yonetici") || User.IsInRole("Lojistik"))
    {
        <a href="@Url.Action("Ekle", "Tasit")" class="btn btn-success">Yeni Taşıt Ekle</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Plaka</th>
                <th>Araç Tipi</th>
                <th>Şoför</th>
                <th>Telefon</th>
                <th>Kapasite</th>
                <th>Sigorta</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.PlakaNo</strong></td>
                    <td>@item.AracTipi</td>
                    <td>@item.SoforAdi</td>
                    <td>@item.SoforTelefon</td>
                    <td>@item.Kapasite kg</td>
                    <td>@item.SigortaNo</td>
                    <td>
                        @if (item.AktifMi)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </td>
                    <td>
                        <a href="@Url.Action("Detay", "Tasit", new { id = item.Id })" class="btn btn-sm btn-primary">Detay</a>
                        @if (User.IsInRole("Yonetici") || User.IsInRole("Lojistik"))
                        {
                            bool hasActiveNakliye = false;
                            if (item.Nakliyeler != null)
                            {
                                foreach (var n in item.Nakliyeler)
                                {
                                    if (n.TasimaBitisTarihi == null)
                                    {
                                        hasActiveNakliye = true;
                                        break;
                                    }
                                }
                            }
                            @if (hasActiveNakliye)
                            {
                                <span class="btn btn-sm btn-secondary" title="Aktif nakliye var">Silinemez</span>
                            }
                            else
                            {
                                <form asp-action="Sil" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bu taşıtı silmek istediğinize emin misiniz?');">Sil</button>
                                </form>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>