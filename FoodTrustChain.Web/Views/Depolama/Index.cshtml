@{
    ViewData["Title"] = "Depolama Kayıtları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
    @if (User.IsInRole("Yonetici") || User.IsInRole("Depo"))
    {
        <a href="@Url.Action("Ekle", "Depolama")" class="btn btn-success">Yeni Depolama Ekle</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Depo</th>
                <th>Ürün</th>
                <th>Giriş</th>
                <th>Çıkış</th>
                <th>Sıcaklık</th>
                <th>Nem</th>
                <th>Hash</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.DepoAdi</td>
                    <td>@item.Urun?.Ad</td>
                    <td>@item.GirisTarihi?.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@item.CikisTarihi?.ToString("dd.MM.yyyy HH:mm") ?? "-"</td>
                    <td>@item.Sicaklik °C</td>
                    <td>@item.NemOrani %</td>
                    <td><code>@item.HashDegeri?.Substring(0, 12)...</code></td>
                    <td>
                        @if (item.CikisTarihi == null)
                        {
                            <a href="@Url.Action("Cikis", "Depolama", new { id = item.Id })" class="btn btn-sm btn-warning">Çıkış Yap</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>