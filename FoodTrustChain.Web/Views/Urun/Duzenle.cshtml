@model FoodTrustChain.Web.Models.Entities.Urun

@{
    ViewData["Title"] = "Ürün Düzenle";
}

<div class="card">
    <div class="card-header bg-warning text-dark">
        <h4>Ürün Düzenle</h4>
    </div>
    <div class="card-body">
        <form asp-action="Duzenle" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Guid" />
            <input type="hidden" asp-for="OlusturmaTarihi" />
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Ürün Adı</label>
                        <input asp-for="Ad" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kategori</label>
                        <select asp-for="Kategori" class="form-select" asp-items="ViewBag.Kategoriler"></select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Üretici</label>
                        <select asp-for="UreticiId" class="form-select" asp-items="ViewBag.Ureticiler"></select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Durum</label>
                        <select asp-for="Durum" class="form-select" asp-items="ViewBag.Durumlar"></select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <textarea asp-for="Aciklama" class="form-control" rows="4"></textarea>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-warning">Güncelle</button>
                <a href="@Url.Action("Index", "Urun")" class="btn btn-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>