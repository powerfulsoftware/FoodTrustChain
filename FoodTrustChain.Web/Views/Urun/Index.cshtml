@{
    ViewData["Title"] = "Ürünler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
    @if (User.IsInRole("Yonetici") || User.IsInRole("Uretici"))
    {
        <a href="@Url.Action("Ekle", "Urun")" class="btn btn-success">Yeni Ürün Ekle</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>GUID</th>
                <th>Ürün Adı</th>
                <th>Kategori</th>
                <th>Üretici</th>
                <th>Durum</th>
                <th>Oluşturma</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><code>@item.Guid.ToString().Substring(0, 8)...</code></td>
                    <td>@item.Ad</td>
                    <td>@item.Kategori</td>
                    <td>@item.Uretici?.Ad @item.Uretici?.Soyad</td>
                    <td>
                        @if (item.Durum == "Satildi")
                        {
                            <span class="badge bg-secondary">Satıldı</span>
                        }
                        else if (item.Durum == "Tasinyor")
                        {
                            <span class="badge bg-warning">Taşınıyor</span>
                        }
                        else if (item.Durum == "Depoda")
                        {
                            <span class="badge bg-info">Depoda</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Üretimde</span>
                        }
                    </td>
                    <td>@item.OlusturmaTarihi.ToString("dd.MM.yyyy")</td>
                    <td>
                        <a href="@Url.Action("Detay", "Urun", new { id = item.Id })" class="btn btn-sm btn-primary">Detay</a>
                        @if (User.IsInRole("Yonetici"))
                        {
                            <a href="@Url.Action("Duzenle", "Urun", new { id = item.Id })" class="btn btn-sm btn-warning">Düzenle</a>
                            <a href="@Url.Action("Sil", "Urun", new { id = item.Id })" class="btn btn-sm btn-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</a>
                            <a href="@Url.Action("Olustur", "QRKod", new { urunId = item.Id })" class="btn btn-sm btn-success" target="_blank">QR</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>