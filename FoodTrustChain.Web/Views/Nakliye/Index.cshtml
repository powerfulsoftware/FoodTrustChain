@{
    ViewData["Title"] = "Nakliye Kayıtları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
    @if (User.IsInRole("Yonetici") || User.IsInRole("Lojistik"))
    {
        <a href="@Url.Action("Ekle", "Nakliye")" class="btn btn-success">Yeni Nakliye Ekle</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Ürün</th>
                <th>Taşıt</th>
                <th>Şoför</th>
                <th>Başlangıç</th>
                <th>Bitiş</th>
                <th>Başlangıç</th>
                <th>Bitiş</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Urun?.Ad</td>
                    <td>@item.Tasit?.PlakaNo</td>
                    <td>@item.SoforAdi</td>
                    <td>@item.BaslangicAdresi</td>
                    <td>@item.BitisAdresi</td>
                    <td>@item.TasimaBaslangicTarihi?.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@item.TasimaBitisTarihi?.ToString("dd.MM.yyyy HH:mm") ?? "-"</td>
                    <td>
                        @if (item.TasimaBitisTarihi == null)
                        {
                            <a href="@Url.Action("Teslim", "Nakliye", new { id = item.Id })" class="btn btn-sm btn-success">Teslim Et</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>