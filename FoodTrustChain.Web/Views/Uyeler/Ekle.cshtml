@model FoodTrustChain.Web.Models.Entities.Uyeler

@{
    ViewData["Title"] = "Üye Ekle";
}

<div class="card">
    <div class="card-header bg-success text-white">
        <h4>Yeni Üye Ekle</h4>
    </div>
    <div class="card-body">
        <form asp-action="Ekle" method="post">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Ad</label>
                        <input asp-for="Ad" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Soyad</label>
                        <input asp-for="Soyad" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">E-posta</label>
                        <input asp-for="Eposta" type="email" class="form-control" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Telefon</label>
                        <input asp-for="Telefon" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Şifre</label>
                        <input name="Sifre" type="password" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Rol</label>
                        <select asp-for="Rol" class="form-select" asp-items="ViewBag.Roller"></select>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-success">Kaydet</button>
                <a href="@Url.Action("Index", "Uyeler")" class="btn btn-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>