@{
    ViewData["Title"] = "Üyeler";
}

@if (TempData["Basari"] != null)
{
    <div class="alert alert-success">@TempData["Basari"]</div>
}
@if (TempData["Hata"] != null)
{
    <div class="alert alert-danger">@TempData["Hata"]</div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
    @if (User.IsInRole("Yonetici"))
    {
        <a href="@Url.Action("Ekle", "Uyeler")" class="btn btn-success">Yeni Üye Ekle</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th>Telefon</th>
                <th>Rol</th>
                <th>Durum</th>
                <th>Oluşturma</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Ad @item.Soyad</td>
                    <td>@item.Eposta</td>
                    <td>@item.Telefon</td>
                    <td>
                        @{
                            var rolClass = item.Rol switch
                            {
                                "Yonetici" => "bg-danger",
                                "Uretici" => "bg-success",
                                "Depo" => "bg-info",
                                "Lojistik" => "bg-warning",
                                "Market" => "bg-primary",
                                "Tuketici" => "bg-secondary",
                                _ => "bg-dark"
                            };
                        }
                        <span class="badge @rolClass">@item.Rol</span>
                    </td>
                    <td>
                        @if (item.AktifMi)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </td>
                    <td>@item.OlusturmaTarihi.ToString("dd.MM.yyyy")</td>
                    <td>
                        <a href="@Url.Action("Detay", "Uyeler", new { id = item.Id })" class="btn btn-sm btn-primary">Detay</a>
                        @if (User.IsInRole("Yonetici"))
                        {
                            <a href="@Url.Action("RolDegistir", "Uyeler", new { id = item.Id })" class="btn btn-sm btn-warning">Rol Değiştir</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>