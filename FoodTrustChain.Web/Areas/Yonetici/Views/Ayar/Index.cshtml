@model IEnumerable<FoodTrustChain.Web.Models.Entities.Ayar>

@{
    ViewData["Title"] = "Sistem Ayarları";
}

@if (TempData["Basari"] != null)
{
    <div class="alert alert-success">@TempData["Basari"]</div>
}
@if (TempData["Hata"] != null)
{
    <div class="alert alert-danger">@TempData["Hata"]</div>
}

<div class="card">
    <div class="card-header bg-dark text-white">
        <h4>Sistem Ayarları</h4>
    </div>
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <p class="text-muted mb-0">Sistem parametrelerini buradan yönetebilirsiniz.</p>
            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#ekleModal">Yeni Ayar Ekle</button>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Anahtar</th>
                            <th>Değer</th>
                            <th>Açıklama</th>
                            <th>Durum</th>
                            <th>Oluşturma</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Anahtar</strong></td>
                                <td>@item.Deger</td>
                                <td>@item.Aciklama</td>
                                <td>
                                    @if (item.AktifMi)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Pasif</span>
                                    }
                                </td>
                                <td>@item.OlusturmaTarihi.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#duzenleModal-@item.Id">Düzenle</button>
                                    <form asp-action="Sil" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</button>
                                    </form>
                                </td>
                            </tr>

                            <div class="modal fade" id="duzenleModal-@item.Id" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header bg-primary text-white">
                                            <h5 class="modal-title">@item.Anahtar - Düzenle</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <form asp-action="Duzenle" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <div class="modal-body">
                                                <div class="mb-3">
                                                    <label class="form-label">Anahtar</label>
                                                    <input class="form-control" value="@item.Anahtar" disabled />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label">Değer</label>
                                                    <input name="deger" class="form-control" value="@item.Deger" />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label">Açıklama</label>
                                                    <input name="aciklama" class="form-control" value="@item.Aciklama" />
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                                                <button type="submit" class="btn btn-primary">Kaydet</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">Henüz ayar bulunmamaktadır.</p>
        }
    </div>
</div>

<div class="modal fade" id="ekleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">Yeni Ayar Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Ekle" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Anahtar</label>
                        <input name="Anahtar" class="form-control" placeholder="ornek_ayar" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Değer</label>
                        <input name="Deger" class="form-control" placeholder="değer" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Açıklama</label>
                        <input name="Aciklama" class="form-control" placeholder="Ayar açıklaması" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-success">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>